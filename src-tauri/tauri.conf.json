{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cofree",
  "version": "0.0.5",
  "identifier": "app.cofree.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cofree",
        "label": "main",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/J-York/Cofree/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczMjMxNDhENzEwMDUwRkEKUldUNlVBQnhqUlFqY3hSNVBNQ0xpR3lxcXhqVmVsT0NnS0tEM3BzcFE0Ujl6YlVFQ211dGlDTk4K"
    }
  }
}
