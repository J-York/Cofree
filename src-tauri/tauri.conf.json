{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cofree",
  "version": "0.1.0",
  "identifier": "app.cofree.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cofree - AI Programming Cafe",
        "label": "main",
        "width": 1200,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
